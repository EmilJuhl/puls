# Livspoint — Miljøvariabler
#
# Kopiér denne fil til .env og udfyld med dine Supabase-credentials:
#   cp .env.example .env
#
# Find disse værdier i Supabase Dashboard → Settings → API
#
# VIGTIGT: Commit aldrig .env til git!

# Din Supabase projekt-URL (f.eks. https://abcdefghijkl.supabase.co)
VITE_SUPABASE_URL=https://yskvxkhefpltgmyajqmt.supabase.co

# Din Supabase anon/public key (den lange JWT-string)
# Denne er sikker at bruge i frontend-kode — den er designet til klient-brug
